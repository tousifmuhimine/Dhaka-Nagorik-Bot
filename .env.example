APP_NAME=Dhaka Nagorik Bot
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
FLET_HOST=127.0.0.1
FLET_PORT=8550

# Primary Database: Supabase Postgres
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project.supabase.co:5432/postgres
# Direct connection pieces if you prefer separate env vars
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-db-password-here
DB_HOST=db.your-project.supabase.co
DB_PORT=5432
DB_SSLMODE=require
DB_CONN_MAX_AGE=600

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here
SUPABASE_VECTOR_TABLE=vector_documents
SUPABASE_VECTOR_MATCH_FUNCTION=match_vector_documents

# AI/LLM Configuration
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Web Search (Tavily)
TAVILY_API_KEY=your-tavily-api-key-here

# Email Configuration
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_FROM_NAME=Dhaka Nagorik Bot
EMAIL_SENDER=noreply@dhakanagorikbot.com

# Feature Flags
ENABLE_EMAIL=true
ENABLE_TAVILY_SEARCH=true
ENABLE_ADVANCED_RAG=false
ENABLE_AUTO_POLICY_INDEXING=false

# Paths / Storage
ENABLE_SUPABASE_STORAGE=true
VECTOR_STORE_BACKEND=supabase
POLICY_DIRECTORY=D:\Codes\Dhaka Nagorik Bot
SUPABASE_MEDIA_BUCKET=complaint-media
SUPABASE_DOCUMENT_BUCKET=generated-documents
SUPABASE_STORAGE_SIGNED_URL_TTL=3600

# Local-only fallback values kept for reference
# LOCAL_STORAGE_PATH=D:\Codes\Dhaka Nagorik Bot\storage
# DOCUMENT_OUTPUT_DIR=D:\Codes\Dhaka Nagorik Bot\generated_docs
# LOCAL_VECTOR_DB_PATH=D:\Codes\Dhaka Nagorik Bot\storage\chroma
# VECTOR_STORE_BACKEND=local
# SQLITE_PATH=D:\Codes\Dhaka Nagorik Bot\db.sqlite3
